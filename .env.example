# ---------------------------------------------------------------------------
# Copy to .env.local for local dev, and set the same vars in Vercel → Settings
# → Environment Variables for production. Never commit real secrets.
# ---------------------------------------------------------------------------

# Admin panel password (required to log in at /admin). Choose a strong value.
ADMIN_PASSWORD=change-me-to-a-long-random-string

# Optional: secret used to sign the admin session cookie. If omitted, the app
# derives a key from ADMIN_PASSWORD. Set a separate long random value in prod.
SESSION_SECRET=another-long-random-string

# ---------------------------------------------------------------------------
# Vercel Postgres connection. When you attach a Postgres database in the Vercel
# dashboard (Storage tab), these are added to your project automatically — you
# normally do NOT set them by hand. For local dev, run `vercel env pull` to
# fetch them into .env.local. Only POSTGRES_URL is strictly required.
# ---------------------------------------------------------------------------
POSTGRES_URL=postgres://user:password@host/dbname?sslmode=require
# POSTGRES_URL_NON_POOLING=
# POSTGRES_PRISMA_URL=
